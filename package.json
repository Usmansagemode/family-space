{
  "name": "family-calendar",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "check": "turbo check",
